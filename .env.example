# ──────────────────────────────────────────────────────────────
# Qual – Environment Configuration Template
# Copy to .env and fill in your own keys.
# ──────────────────────────────────────────────────────────────

# ── API Authentication (production required) ──────────────────
# Comma-separated list of valid API keys sent as X-API-Key header.
# Leave empty to run in dev/open mode (no auth enforced).
API_KEYS=your-secret-key-1,your-secret-key-2

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_LLM=20/minute

# ── LLM / Ollama (local) ─────────────────────────────────────
OLLAMA_URL=http://localhost:11434
LLM_MODEL=mistral:latest
LLM_NUM_CTX=4096
LLM_NUM_PREDICT=800
LLM_TEMPERATURE=0.15
OLLAMA_GENERATE_TIMEOUT_SEC=90
OLLAMA_EMBED_TIMEOUT_SEC=6
OLLAMA_CONNECT_TIMEOUT_SEC=5

# ── Cloud LLM Provider ──────────────────────────────────────
# Supported: groq | gemini | openrouter | together | mistral | cerebras | nvidia | ollama
# Set LLM_PROVIDER to a cloud provider and fill in LLM_CLOUD_API_KEY.
# Sign up for free: Groq (console.groq.com), Gemini (aistudio.google.com)
LLM_PROVIDER=ollama
LLM_CLOUD_API_KEY=
LLM_CLOUD_MODEL=
LLM_CLOUD_BASE_URL=
LLM_CLOUD_TIMEOUT_SEC=30
LLM_PROVIDER_ORDER=cloud,ollama
# For Google Gemini specifically (uses its own REST endpoint):
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Quality Gating ───────────────────────────────────────────
# Auto-retry with rewrite prompt when quality score < threshold.
QUALITY_GATE_ENABLED=1
QUALITY_GATE_THRESHOLD=55

# ── Embeddings / Vector DB ───────────────────────────────────
# If you change embedding provider or model, rebuild the index.
EMBED_PROVIDER=ollama
EMBED_MODEL=nomic-embed-text
# EMBED_MODEL_FINANCE=nomic-embed-text
# EMBED_USE_PREFIX=0

# ── External Data APIs ────────────────────────────────────────
# FRED (Federal Reserve Economic Data) — free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here
# Alpha Vantage fallback — free at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# ── Response Cache TTLs (seconds) ─────────────────────────────
ASK_CACHE_TTL=300
INTEL_CACHE_TTL=300
MARKET_DATA_CACHE_TTL=900
LIVE_DATA_CACHE_TTL=300

# ── Network Timeouts (seconds) ────────────────────────────────
FRED_TIMEOUT_SEC=5
YF_TIMEOUT_SEC=12
LIVE_DATA_TIMEOUT_SEC=6

# ── RSS Ingestion Settings ────────────────────────────────────
RSS_MAX_AGE_DAYS=7
RSS_MAX_PER_FEED=20
RSS_FETCH_FULL_TEXT=1
RSS_REQUEST_TIMEOUT=10
RSS_MAX_WORKERS=6

# ── Ingestion Scheduler ───────────────────────────────────────
# Interval between RSS refresh runs (minutes)
SCHEDULER_RSS_INTERVAL_MIN=30
# Interval between full index rebuilds (hours)
SCHEDULER_INDEX_INTERVAL_HOURS=6

# ── Data Paths ────────────────────────────────────────────────
FEEDBACK_LOG_PATH=data/feedback_log.jsonl
QUERY_LOG_PATH=data/query_log.jsonl

# ── Server ────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=info

# ── App Branding ──────────────────────────────────────────────
APP_BRAND_NAME="Macro AI"

# ── MCP Integration ──────────────────────────────────────────
# If unset, MCP falls back to API_KEYS for read/admin auth.
MCP_READ_KEYS=
MCP_ADMIN_KEYS=
MCP_HOST=127.0.0.1
MCP_PORT=8010
MCP_REQUIRE_ORIGIN_CHECK=0
MCP_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
MCP_CONFIRMATION_TTL_SEC=180
MCP_IDEMPOTENCY_TTL_SEC=3600
MCP_AUDIT_LOG_PATH=data/mcp_audit_log.jsonl
MCP_CLIENT_TIMEOUT_SEC=20

# JSON object with outbound MCP client server definitions.
# Example:
# MCP_CLIENT_SERVERS_JSON={"internal-tools":{"transport":"streamable-http","url":"http://localhost:9000/mcp"}}
MCP_CLIENT_SERVERS_JSON={}

# Optional runtime MCP enrichment hooks
RAG_ENABLE_MCP_ENRICHMENT=0
RAG_MCP_SERVER=
RAG_MCP_TOOL=
RAG_MCP_TIMEOUT_SEC=6
RAG_MCP_MAX_CHARS=700

MACRO_ENABLE_MCP_ENRICHMENT=0
MACRO_MCP_SERVER=
MACRO_MCP_TOOL=
MACRO_MCP_TIMEOUT_SEC=6
MACRO_MCP_MAX_CHARS=700
