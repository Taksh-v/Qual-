# ──────────────────────────────────────────────────────────────
# Qual – Environment Configuration Template
# Copy to .env and fill in your own keys.
# ──────────────────────────────────────────────────────────────

# FRED API key (free at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# Alpha Vantage API key (free at https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Ollama server URL (default: local)
OLLAMA_URL=http://localhost:11434

# Timeouts (seconds)
OLLAMA_EMBED_TIMEOUT_SEC=6
OLLAMA_GENERATE_TIMEOUT_SEC=350
OLLAMA_CONNECT_TIMEOUT_SEC=5
LIVE_DATA_TIMEOUT_SEC=6

# RSS ingestion settings
RSS_MAX_AGE_DAYS=7
RSS_MAX_PER_FEED=20
RSS_FETCH_FULL_TEXT=1
RSS_REQUEST_TIMEOUT=10
RSS_MAX_WORKERS=6

# Live data TTL cache (seconds before refreshing market data)
LIVE_DATA_CACHE_TTL=300

# App branding
APP_BRAND_NAME=Macro AI
